# Loom .env example. Copy to .env and fill in.
# Anything in loom.toml can also be supplied via these env vars.

# --- Provider selection: "vertex" or "openrouter" ---
LOOM_PROVIDER=vertex

# --- TLS (apply to Vault, Vertex, and OpenRouter) ---
# Point at your corporate CA bundle if you're behind a TLS-intercepting proxy.
# LOOM_TLS_CA_BUNDLE=/etc/ssl/certs/corporate-ca.pem
# Last resort: disable cert verification entirely (NOT recommended).
# LOOM_TLS_VERIFY=false

# --- OpenRouter (used when LOOM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7

# --- Vertex (used when LOOM_PROVIDER=vertex) ---
VERTEX_PROJECT_ID=
VERTEX_REGION=us-east5
VERTEX_MODEL=claude-opus-4-6

# --- HashiCorp Vault (used to source Vertex GCP credentials) ---
VAULT_URL=
VAULT_NAMESPACE=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
# Path to read after AppRole login. For Vault's GCP secrets engine roleset,
# this looks like "gcp/token/<roleset-name>" and returns an OAuth access token.
VAULT_TOKEN_PATH=
# Vault-only TLS overrides (for internal CAs not in your OS trust store).
# Setting either of these affects ONLY the Vault HTTPS calls; Vertex and
# OpenRouter continue to verify normally.
# VAULT_TLS_CA_BUNDLE=/path/to/internal-vault-ca.pem
# VAULT_TLS_VERIFY=false
